# Database (Neon - provision via Vercel Storage, EU region)
DATABASE_URL=

# Base URL for Stripe redirects (e.g. https://soirdematch.fr).
# Optionnel sur Vercel (VERCEL_URL sert de repli) ; requis pour un domaine personnalisé.
APP_BASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Meta Conversions API
META_PIXEL_ID=
META_CAPI_TOKEN=

# Vercel Blob storage
BLOB_READ_WRITE_TOKEN=

# Admin access
ADMIN_PASSWORD=
